#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = [
#     "mdformat",
#     "tomlkit",
#     "pytest",
# ]
# ///

"""Formats markdown inside TOML files."""

import argparse
import sys

import mdformat
import tomlkit
from tomlkit.items import String


def format_markdown_string(text: str, wrap_length: int) -> str:
    """Formats a single markdown string with a specified wrap length."""
    formatted = mdformat.text(text, options={"number": True, "wrap": wrap_length})
    # TOML ignores the first newline after """. For readability, we always add
    # a leading newline to multiline strings if they contain one.
    if not formatted.startswith("\n"):
        formatted = "\n" + formatted

    return formatted


def walk_and_format(node, wrap_length: int, changed=False):
    """Recursively walks a TOML document and formats markdown strings."""
    if isinstance(node, dict):
        for k, v in node.items():
            if isinstance(v, (dict, list)):
                changed = walk_and_format(v, wrap_length, changed)
            elif isinstance(v, String):
                original_text = v.unwrap()
                if "\n" in original_text:
                    formatted_text = format_markdown_string(original_text, wrap_length)
                    if "\n" not in original_text and "\n" in formatted_text:
                        continue  # only format things that were already multiline

                    # compare ignoring the leading newline that we force
                    orig_cmp = (
                        original_text
                        if not original_text.startswith("\n")
                        else original_text[1:]
                    )
                    form_cmp = (
                        formatted_text
                        if not formatted_text.startswith("\n")
                        else formatted_text[1:]
                    )

                    if orig_cmp != form_cmp:
                        node[k] = tomlkit.string(formatted_text, multiline=True)
                        changed = True
    elif isinstance(node, list):
        for i, v in enumerate(node):
            if isinstance(v, (dict, list)):
                changed = walk_and_format(v, wrap_length, changed)
            elif isinstance(v, String):
                original_text = v.unwrap()
                if "\n" in original_text:
                    formatted_text = format_markdown_string(original_text, wrap_length)
                    orig_cmp = (
                        original_text
                        if not original_text.startswith("\n")
                        else original_text[1:]
                    )
                    form_cmp = (
                        formatted_text
                        if not formatted_text.startswith("\n")
                        else formatted_text[1:]
                    )

                    if orig_cmp != form_cmp:
                        node[i] = tomlkit.string(formatted_text, multiline=True)
                        changed = True
    return changed


def test_format_toml():
    """Runs tests to verify the TOML formatting works correctly."""
    print("Running tests...")

    # Test format_markdown_string directly
    text = (
        "\n# Heading 1\n\nSome long text that should be wrapped because "
        "it exceeds the specified wrap length of 40 characters.\n"
    )
    formatted = format_markdown_string(text, 40)
    assert "\n" in formatted
    assert "wrapped\nbecause" in formatted, "Text should be wrapped"

    # Test walk_and_format
    toml_content = '''
description = "Short desc"
prompt = """
# Task

This is a long task description that should be wrapped at 40 characters limit.
"""
'''
    doc = tomlkit.parse(toml_content)
    changed = walk_and_format(doc, wrap_length=40)
    assert changed is True

    updated_toml = tomlkit.dumps(doc)
    assert "description that\nshould be wrapped" in updated_toml, (
        "Multiline string in TOML should be wrapped"
    )
    assert 'description = "Short desc"' in updated_toml, (
        "Single line strings should not be modified"
    )

    # Run a second time to ensure no further changes
    doc2 = tomlkit.parse(updated_toml)
    changed2 = walk_and_format(doc2, wrap_length=40)
    assert changed2 is False, "Should not change already formatted content"

    print("All tests passed.")


def main():
    """Main CLI entry point for toml-mdformat."""
    parser = argparse.ArgumentParser(description="Format markdown inside TOML files.")
    parser.add_argument(
        "--check",
        action="store_true",
        help="Check if files need formatting without modifying them.",
    )
    parser.add_argument(
        "--wrap",
        type=int,
        default=80,
        help="Line length for markdown wrapping.",
    )
    parser.add_argument("files", nargs="*", help="TOML files to format.")

    args = parser.parse_args()

    if not args.files:
        parser.print_usage()
        sys.exit(1)

    any_changed = False

    for file_path in args.files:
        with open(file_path, encoding="utf-8") as f:
            content = f.read()

        doc = tomlkit.parse(content)

        changed = walk_and_format(doc, wrap_length=args.wrap)

        if changed:
            any_changed = True
            if args.check:
                print(f"Would format {file_path}")
            else:
                with open(file_path, "w", encoding="utf-8") as f:
                    f.write(tomlkit.dumps(doc))
                print(f"Formatted {file_path}")

    if args.check and any_changed:
        sys.exit(1)


if __name__ == "__main__":
    main()
