#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.14"
# dependencies = []
# ///
"""
Checks status of Gemini CLI instances in tmux panes.

Usage:
  gemini-status          # Output for tmux status bar (e.g. "✋ 1 ✦ 2 ◇ 1")
  gemini-status --list   # List details of active instances
  gemini-status --jump   # Interactive menu to jump to an instance
"""

import argparse
import glob
import hashlib
import json
import logging
import os
import subprocess
import sys
import termios
import tty
from collections.abc import Callable
from typing import TypedDict

GEMINI_HOME = os.path.expanduser("~/.gemini")
PROJECTS_JSON = os.path.join(GEMINI_HOME, "projects.json")

logger = logging.getLogger(__name__)


class PaneInfo(TypedDict):
    """Represents a single tmux pane containing a Gemini instance."""

    session: str
    window: str
    pane: str
    title: str
    status: str
    target: str
    summary: str | None
    pane_pid: str


def get_git_root(path: str) -> str:
    """Finds the git root for the given path, or returns the path itself."""
    cmd = ["git", "-C", path, "rev-parse", "--show-toplevel"]
    root = subprocess.check_output(cmd, stderr=subprocess.DEVNULL, text=True).strip()
    return root


def get_project_tmp_dir(
    project_path: str,
    projects_json_path: str = PROJECTS_JSON,
    gemini_home: str = GEMINI_HOME,
) -> str:
    """
    Determines the temporary directory for a project.
    Checks ~/.gemini/projects.json for named projects, otherwise uses hash.
    """
    projects: dict[str, str] = {}
    if os.path.exists(projects_json_path):
        with open(projects_json_path) as f:
            data = json.load(f)
            projects = data.get("projects", {})

    if project_path in projects:
        return os.path.join(gemini_home, "tmp", projects[project_path])

    project_hash = hashlib.sha256(project_path.encode()).hexdigest()
    return os.path.join(gemini_home, "tmp", project_hash)


def get_session_summary(
    project_root: str,
    session_id: str,
    tmp_dir_resolver: Callable[[str], str] = get_project_tmp_dir,
) -> str | None:
    """Retrieves the summary from the correct session JSON file."""
    project_tmp = tmp_dir_resolver(project_root)
    chats_dir = os.path.join(project_tmp, "chats")

    pattern = os.path.join(chats_dir, f"session-*{session_id}*.json")
    files = glob.glob(pattern)

    if not files:
        short_id = session_id.split("-")[0]
        pattern = os.path.join(chats_dir, f"session-*{short_id}*.json")
        files = glob.glob(pattern)

    if not files:
        logger.debug(f"Could not find any session file for {session_id} in {chats_dir}")
        return None

    files.sort(key=os.path.getmtime, reverse=True)
    latest_session_file = files[0]

    try:
        with open(latest_session_file) as f:
            session_data = json.load(f)

            # Use generated summary if available
            summary = session_data.get("summary")
            if summary:
                logger.debug(f"Found 'summary' key in {latest_session_file}")
                return summary

            # Fallback to the user's initial prompt
            messages = session_data.get("messages", [])
            if messages:
                first_msg = messages[0]
                content = first_msg.get("displayContent") or first_msg.get("content")
                if content and isinstance(content, list) and content[0].get("text"):
                    logger.debug(f"Fell back to first message text in {latest_session_file}")
                    return content[0]["text"].split("\n")[0][:60]

            logger.debug(f"No summary or messages found in {latest_session_file}")
            return None
    # Catch JSONDecodeError/OSError to gracefully handle race conditions where
    # the active Gemini process is concurrently writing to or rotating the file.
    except (json.JSONDecodeError, OSError) as e:
        logger.debug(f"Failed to read or parse {latest_session_file}: {e}")
        return None


def parse_tmux_output(
    output: str,
    summary_fetcher: Callable[[str, str], str | None] | None = None,
    pid_map: dict[str, str] | None = None,
) -> list[PaneInfo]:
    """Parses 'tmux list-panes' output into a list of PaneInfo dicts."""
    panes: list[PaneInfo] = []
    for line in output.strip().split("\n"):
        if not line:
            continue
        parts = line.split("\t")
        if len(parts) < 6:
            continue

        session, window, pane, title, cwd, pane_pid = parts

        status = None
        if "✋" in title:
            status = "waiting"
        elif "✦" in title:
            status = "working"
        elif "◇" in title:
            status = "idle"

        if status:
            target = f"{session}:{window}.{pane}"
            summary = None
            if summary_fetcher and pid_map is not None:
                if pane_pid in pid_map:
                    logger.debug(
                        f"Pane PID {pane_pid} found in map -> Session {pid_map[pane_pid]}"
                    )
                    project_root = get_git_root(cwd)
                    summary = summary_fetcher(project_root, pid_map[pane_pid])
                else:
                    logger.debug(f"Pane PID {pane_pid} not found in tracking map.")

            panes.append(
                {
                    "session": session,
                    "window": window,
                    "pane": pane,
                    "title": title.strip(),
                    "status": status,
                    "target": target,
                    "summary": summary,
                    "pane_pid": pane_pid,
                }
            )
    return panes


def get_tmux_panes(
    fetch_summary: bool = False, pid_map: dict[str, str] | None = None
) -> list[PaneInfo]:
    """Retrieves and parses active tmux panes containing Gemini markers."""
    # Use tabs as separators to handle spaces in titles correctly
    cmd = [
        "tmux",
        "list-panes",
        "-a",
        "-F",
        "#{session_name}\t#{window_index}\t#{pane_index}\t#{pane_title}\t#{pane_current_path}\t#{pane_pid}",
    ]
    try:
        output = subprocess.check_output(cmd, text=True)
    except (subprocess.CalledProcessError, FileNotFoundError):
        return []

    fetcher = get_session_summary if fetch_summary else None
    return parse_tmux_output(output, summary_fetcher=fetcher, pid_map=pid_map)


def print_status_bar(panes: list[PaneInfo]) -> None:
    """Prints a condensed status for the tmux status-right line."""
    waiting = [p for p in panes if p["status"] == "waiting"]
    working = [p for p in panes if p["status"] == "working"]
    idle = [p for p in panes if p["status"] == "idle"]

    output_parts = []
    if waiting:
        # Red hand, Yellow number for waiting attention
        output_parts.append(
            f"#[fg=colour196,bold]✋ #[fg=colour226]{len(waiting)}#[default]"
        )
    if working:
        # Gray for working (matching non-selected windows)
        output_parts.append(f"#[fg=colour244,dim]✦ {len(working)}#[default]")
    if idle:
        # Blue for idle
        output_parts.append(f"#[fg=colour33,bold]◇ {len(idle)}#[default]")

    if output_parts:
        print(" " + " ".join(output_parts))


def print_list(panes: list[PaneInfo]) -> None:
    """Prints a detailed list of active Gemini instances."""
    if not panes:
        print("No active Gemini instances found.")
        return

    # Group by session
    by_session: dict[str, list[PaneInfo]] = {}
    for p in panes:
        by_session.setdefault(p["session"], []).append(p)

    for session, p_list in by_session.items():
        print(f"Session: {session}")
        for p in p_list:
            if p["status"] == "waiting":
                icon = "✋"
            elif p["status"] == "working":
                icon = "✦"
            else:
                icon = "◇"

            desc = p["title"]
            if p["summary"]:
                desc += f" ({p['summary']})"
            print(f"  {icon}  Window {p['window']}.{p['pane']}: {desc}")


def get_key() -> str:
    """Reads a single keypress from stdin."""
    fd = sys.stdin.fileno()
    old_settings = termios.tcgetattr(fd)
    try:
        tty.setraw(sys.stdin.fileno())
        ch = sys.stdin.read(1)
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)
    return ch


def interactive_jump(panes: list[PaneInfo]) -> None:
    """Displays an interactive menu to switch to a specific tmux pane."""
    if not panes:
        print("No active Gemini instances found.")
        # Wait for a keypress so the popup doesn't close immediately
        print("Press any key to close...")
        get_key()
        return

    # Generate keys: 1-9, then a-z
    keys = [str(i) for i in range(1, 10)] + [chr(i) for i in range(ord("a"), ord("z") + 1)]

    mapping: dict[str, PaneInfo] = {}
    print("\033[1mSelect a Gemini instance to jump to:\033[0m")

    # Sort panes: waiting (0), working (1), idle (2), then by session/window
    def sort_key(x: PaneInfo) -> tuple[int, str, str]:
        priority = {"waiting": 0, "idle": 1, "working": 2}
        return (priority.get(x["status"], 3), x["session"], x["window"])

    panes.sort(key=sort_key)

    for i, p in enumerate(panes):
        if i >= len(keys):
            break
        key = keys[i]
        mapping[key] = p

        if p["status"] == "waiting":
            icon = "✋"
            color_code = "\033[1;38;5;196m"  # Bold Red
        elif p["status"] == "working":
            icon = "✦"
            color_code = "\033[38;5;244m"  # Gray (Not Bold)
        else:
            icon = "◇"
            color_code = "\033[1;38;5;33m"  # Bold Blue

        desc = p["title"]
        if p["summary"]:
            summary = p["summary"]
            if len(summary) > 60:
                summary = summary[:57] + "..."
            desc = f"\033[3m{summary}\033[0m"

        print(
            f" [\033[1;33m{key}\033[0m] {color_code}{icon}\033[0m "
            f"{p['session']}:{p['window']} - {desc}"
        )

    print("\n(Press 'q' or Esc to cancel)")

    key = get_key()

    if key in mapping:
        target = mapping[key]["target"]
        subprocess.run(["tmux", "switch-client", "-t", target], check=False)
    elif key in ("q", "\x1b"):  # q or ESC
        return


def test_parse_tmux_output() -> None:
    """Tests parsing tmux output."""
    raw = (
        "sess1\t0\t0\t✋ gemini: working\t/tmp\t1234\n"
        "sess1\t0\t1\t✦ gemini: thinking\t/tmp\t5678\n"
        "sess2\t1\t0\t◇ gemini: idle\t/tmp\t9012\n"
        "sess2\t2\t0\tregular bash\t/tmp\t3456\n"
    )
    panes = parse_tmux_output(raw)
    assert len(panes) == 3

    assert panes[0]["status"] == "waiting"
    assert panes[0]["target"] == "sess1:0.0"
    assert panes[0]["summary"] is None
    assert panes[0]["pane_pid"] == "1234"

    assert panes[1]["status"] == "working"
    assert panes[1]["target"] == "sess1:0.1"
    assert panes[1]["summary"] is None
    assert panes[1]["pane_pid"] == "5678"

    assert panes[2]["status"] == "idle"
    assert panes[2]["target"] == "sess2:1.0"
    assert panes[2]["summary"] is None
    assert panes[2]["pane_pid"] == "9012"


def test_sort_logic() -> None:
    """Tests sorting of tmux panes."""
    panes: list[PaneInfo] = [
        {
            "status": "idle",
            "session": "a",
            "window": "1",
            "pane": "0",
            "title": "idle",
            "target": "a:1.0",
            "summary": None,
            "pane_pid": "123",
        },
        {
            "status": "waiting",
            "session": "b",
            "window": "1",
            "pane": "0",
            "title": "waiting",
            "target": "b:1.0",
            "summary": None,
            "pane_pid": "456",
        },
        {
            "status": "working",
            "session": "a",
            "window": "2",
            "pane": "0",
            "title": "working",
            "target": "a:2.0",
            "summary": None,
            "pane_pid": "789",
        },
    ]

    def sort_key(x: PaneInfo) -> tuple[int, str, str]:
        priority = {"waiting": 0, "idle": 1, "working": 2}
        return (priority.get(x["status"], 3), x["session"], x["window"])

    panes.sort(key=sort_key)
    assert panes[0]["status"] == "waiting"
    assert panes[1]["status"] == "idle"
    assert panes[2]["status"] == "working"


def test_get_project_tmp_dir(tmp_path) -> None:
    """Tests project tmp dir resolution."""
    gemini_home = tmp_path / ".gemini"
    gemini_home.mkdir()
    projects_json = gemini_home / "projects.json"

    # Test successful resolution of named project
    projects_json.write_text('{"projects": {"/my/proj": "proj-hash"}}')
    assert get_project_tmp_dir(
        "/my/proj", str(projects_json), str(gemini_home)
    ) == os.path.join(str(gemini_home), "tmp", "proj-hash")

    # Test fallback to hash
    project_hash = hashlib.sha256(b"/unknown/proj").hexdigest()
    assert get_project_tmp_dir(
        "/unknown/proj", str(projects_json), str(gemini_home)
    ) == os.path.join(str(gemini_home), "tmp", project_hash)

    # Test malformed JSON raises JSONDecodeError
    projects_json.write_text('{"projects": malformed}')
    try:
        get_project_tmp_dir("/my/proj", str(projects_json), str(gemini_home))
        raise AssertionError("Expected JSONDecodeError")
    except json.JSONDecodeError:
        pass


def test_get_session_summary(tmp_path) -> None:
    """Tests session summary extraction."""
    gemini_home = tmp_path / ".gemini"
    gemini_home.mkdir()
    project_tmp = gemini_home / "tmp" / "test-hash"
    project_tmp.mkdir(parents=True)
    chats_dir = project_tmp / "chats"
    chats_dir.mkdir()

    def tmp_dir_resolver(p):
        return str(project_tmp)

    # Test failure: session files missing
    assert get_session_summary("/proj", "12345", tmp_dir_resolver=tmp_dir_resolver) is None

    # Write session file
    session_file = chats_dir / "session-12345.json"
    session_file.write_text(json.dumps({"summary": "This is a test summary"}))

    # Test success
    assert (
        get_session_summary(
            "/proj",
            "12345",
            tmp_dir_resolver=tmp_dir_resolver,
        )
        == "This is a test summary"
    )

    # Intentionally malform the session file
    session_file.write_text('{"summary": malformed')
    assert (
        get_session_summary(
            "/proj",
            "12345",
            tmp_dir_resolver=tmp_dir_resolver,
        )
        is None
    )


def test_parse_tmux_output_with_summary() -> None:
    """Tests parsing tmux output with summary fetching."""

    def mock_fetcher(p, s):
        return "Mocked Summary" if s == "my_session" else None

    pid_map = {"1234": "my_session"}
    raw = f"sess1\t0\t0\t✋ gemini: working\t{os.getcwd()}\t1234\n"
    panes = parse_tmux_output(raw, summary_fetcher=mock_fetcher, pid_map=pid_map)

    assert len(panes) == 1
    assert panes[0]["target"] == "sess1:0.0"
    assert panes[0]["summary"] == "Mocked Summary"
    assert panes[0]["pane_pid"] == "1234"


def main() -> None:
    """Main CLI entry point."""
    parser = argparse.ArgumentParser()
    parser.add_argument("--list", "-l", action="store_true", help="List details")
    parser.add_argument("--jump", "-j", action="store_true", help="Interactive jump menu")
    parser.add_argument("-v", "--verbose", action="store_true", help="Enable debug logging")
    args = parser.parse_args()

    level = logging.DEBUG if args.verbose else logging.WARNING
    logging.basicConfig(level=level, format="%(levelname)s: %(message)s")

    fetch_summary = args.list or args.jump

    pid_map = {}
    if fetch_summary:
        map_file = os.path.join(GEMINI_HOME, "tmp", "pid_session_map.json")
        if os.path.exists(map_file):
            with open(map_file) as f:
                pid_map = json.load(f)
        else:
            logger.debug(f"Tracking map not found at {map_file}")

    panes = get_tmux_panes(fetch_summary=fetch_summary, pid_map=pid_map)

    if args.jump:
        interactive_jump(panes)
    elif args.list:
        print_list(panes)
    else:
        print_status_bar(panes)


if __name__ == "__main__":
    main()
