#!/bin/bash
# Usage: gemini-native-sandbox [args...]

set -e

MOCK_DOCKER_DIR=$(mktemp -d)
trap 'rm -rf "$MOCK_DOCKER_DIR"' EXIT

cat << 'EOF' > "$MOCK_DOCKER_DIR/docker"
#!/bin/bash
if [ "$1" == "images" ] && [ "$2" == "-q" ]; then
  echo "mock_image_id_12345"
  exit 0
fi

if [ "$1" == "pull" ]; then
  exit 0
fi

if [ "$1" != "run" ]; then
  exec /usr/bin/docker "$@"
fi

# We have a `docker run` command. Extract the entrypoint arguments.
# The original command generated by Gemini CLI ends with `bash -c "..."`.
ENTRYPOINT_ARGS=()
found_bash=0
for arg in "$@"; do
  if [ "$found_bash" -eq 1 ]; then
    ENTRYPOINT_ARGS+=("$arg")
  elif [ "$arg" == "bash" ]; then
    found_bash=1
  fi
done

if [ "$found_bash" -eq 1 ] && [ "${ENTRYPOINT_ARGS[0]}" == "-c" ]; then
  payload="${ENTRYPOINT_ARGS[1]}"
  if [[ "$payload" =~ su[[:space:]]+-p[[:space:]]+[a-zA-Z0-9_-]+[[:space:]]+-c[[:space:]]+\'(.*)\'[[:space:]]*$ ]]; then
    clean_payload="${BASH_REMATCH[1]}"
    # Prevent infinite recursion by stripping the --sandbox flag from the inner payload
    clean_payload="${clean_payload/--sandbox/}"
    ENTRYPOINT_ARGS=("-c" "$clean_payload")
  fi
  ENTRYPOINT_ARGS=("bash" "${ENTRYPOINT_ARGS[@]}")
else
  # Fallback if no bash is found
  ENTRYPOINT_ARGS=("$@")
fi

WORKSPACE="$PWD"

RW_PATHS=(
  "/tmp"
  "/export/hda3/tmp"
  "/run"
  "$WORKSPACE"
  "$HOME/.gemini"
  "$HOME/.cache"
  "/usr/local/google/_blaze_$USER"
)

if [[ "$WORKSPACE" =~ ^(/google/src/cloud/[^/]+/[^/]+) ]]; then
  RW_PATHS+=("${BASH_REMATCH[1]}")
fi

DOCKER_ARGS=(
  "-i"
  "--rm"
  "--net=host"
  "--ipc=host"
  "--pid=host"
  "-v" "/:/real-root:ro"
  "-v" "/dev:/real-root/dev:ro"
  "-v" "/proc:/real-root/proc:ro"
  --device /dev/kvm
)

if [ -t 0 ]; then
  DOCKER_ARGS+=("-t")
fi

for path in "${RW_PATHS[@]}"; do
  if [ -e "$path" ]; then
    real_path=$(realpath "$path")
    if [ -d "$real_path" ]; then
      DOCKER_ARGS+=("-v" "$real_path:/real-root$real_path")
    fi
  fi
done

# Strip the MOCK_DOCKER_DIR from the PATH so the inner container uses real binaries
CLEAN_PATH=$(echo "$PATH" | sed -e "s|[^:]*/tmp/tmp.[^:]*:||g")

ENV_VARS=(
  "PATH=$CLEAN_PATH"
  "HOME=$HOME"
  "USER=$USER"
  "LOGNAME=$LOGNAME"
  "GEMINI_API_KEY=$GEMINI_API_KEY"
  "TERM=$TERM"
  "SANDBOX=hacky-docker"
)

for env_var in "${ENV_VARS[@]}"; do
  DOCKER_ARGS+=("-e" "$env_var")
done

exec /usr/bin/docker run "${DOCKER_ARGS[@]}" busybox:latest chroot /real-root env --chdir="$WORKSPACE" setpriv --reuid "$(id -u)" --regid "$(id -g)" --init-groups "${ENTRYPOINT_ARGS[@]}"
EOF

chmod +x "$MOCK_DOCKER_DIR/docker"

export PATH="$MOCK_DOCKER_DIR:$PATH"
export GEMINI_SANDBOX=docker

if [ -n "$TMUX" ]; then
  tmux rename-window "g" || true
fi

exec gemini --sandbox --proxy=false "$@"
