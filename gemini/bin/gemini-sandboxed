#!/bin/bash
# Usage: gemini-sandboxed [args...]

set -e

WORKSPACE="$PWD"

RW_PATHS=(
  "/tmp"
  "/export/hda3/tmp"
  "/run"
  "$WORKSPACE"
  "$HOME/.gemini"
  "$HOME/.cache"
  "$HOME/.local/share/uv"
  "$HOME/.local/state/bbwf"
  "/usr/local/google/_blaze_$USER"
)

if [[ "$WORKSPACE" =~ ^(/google/src/cloud/[^/]+/[^/]+) ]]; then
  RW_PATHS+=("${BASH_REMATCH[1]}")
fi

DOCKER_ARGS=(
  "-i"
  "--rm"
  "--net=host"
  "--ipc=host"
  "--pid=host"
  "--cap-add=SYS_ADMIN"
  "--security-opt" "apparmor=unconfined"
  "--security-opt" "seccomp=unconfined"
  "-v" "/:/real-root:ro"
  "-v" "/dev:/real-root/dev:ro"
  "-v" "/proc:/real-root/proc:ro"
  "--device" "/dev/kvm"
)

if [ -t 0 ]; then
  DOCKER_ARGS+=("-t")
fi

for path in "${RW_PATHS[@]}"; do
  # Resolve to actual physical path to handle symlinks (like /export/hda3) safely
  if [ -e "$path" ]; then
    real_path=$(realpath "$path")
    if [ -d "$real_path" ]; then
      DOCKER_ARGS+=("-v" "$real_path:/real-root$real_path")
    fi
  fi
done

ENV_VARS=(
  "PATH=$PATH"
  "HOME=$HOME"
  "USER=$USER"
  "LOGNAME=$LOGNAME"
  "GEMINI_API_KEY=$GEMINI_API_KEY"
  "TERM=$TERM"
  "SANDBOX=sandboxed"
)

for env_var in "${ENV_VARS[@]}"; do
  DOCKER_ARGS+=("-e" "$env_var")
done

exec docker run "${DOCKER_ARGS[@]}" busybox:latest sh -c '
  mkdir -p /real-root/tmp/old_root
  mount --rbind /real-root /real-root
  cd /real-root
  pivot_root . tmp/old_root
  umount -l /tmp/old_root
  mount -t proc proc /proc
  WORKSPACE=$1; shift
  REUID=$1; shift
  REGID=$1; shift
  exec env --chdir="$WORKSPACE" setpriv --reuid "$REUID" --regid "$REGID" --init-groups gemini --proxy=false "$@"
' -- "$WORKSPACE" "$(id -u)" "$(id -g)" "$@"
