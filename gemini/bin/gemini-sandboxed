#!/usr/bin/env -S uv run --script
# Usage: gemini-sandboxed.py [args...]
#
# /// script
# requires-python = ">=3.13"
# ///

import argparse
import os
import re
import sys
from pathlib import Path


def valid_dir(path_str: str) -> Path:
    path_obj = Path(path_str).expanduser().resolve()
    if not path_obj.exists():
        raise argparse.ArgumentTypeError(f"'{path_str}' does not exist")
    if not path_obj.is_dir():
        raise argparse.ArgumentTypeError(f"'{path_str}' is not a valid directory")
    return path_obj


def main() -> None:
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--rw-path", action="append", type=valid_dir, default=[])
    parser.add_argument("--tmpfs", action="append", type=valid_dir, default=[])
    args, gemini_args = parser.parse_known_args(sys.argv[1:])

    _run_gemini(
        extra_rw_paths=args.rw_path,
        tmpfs_paths=args.tmpfs,
        cli_args=gemini_args,
    )


def _run_gemini(extra_rw_paths: list[Path], tmpfs_paths: list[Path], cli_args: list[str]) -> None:
    cwd = os.getcwd()
    uid = os.getuid()
    gid = os.getgid()
    is_tty = sys.stdin.isatty()

    env_vars = _get_allowlisted_env_vars(os.environ)
    # `gemini-cli` displays the contents of `$SANDBOX` in the footer.
    env_vars |= {"SANDBOX": "sandboxed"}

    rw_paths = _get_rw_paths(cwd)
    rw_paths.extend(extra_rw_paths)

    docker_cmd = _build_docker_command(
        cwd=cwd,
        uid=uid,
        gid=gid,
        is_tty=is_tty,
        rw_paths=rw_paths,
        tmpfs_paths=tmpfs_paths,
        env_vars=env_vars,
        cli_args=cli_args,
    )

    # Replace the current process with docker
    os.execvp(docker_cmd[0], docker_cmd)


def _get_allowlisted_env_vars(environ: dict[str, str]) -> dict[str, str]:
    allowlist = ["PATH", "HOME", "USER", "LOGNAME", "GEMINI_API_KEY", "TERM"]
    return {name: environ[name] for name in allowlist if name in environ}


def _generate_rw_paths(cwd: str) -> list[str]:
    paths = [
        "/tmp",
        "/export/hda3/tmp",
        "/run",
        cwd,
        "~/.gemini",
        "~/.cache",
        "~/.local/share/uv",
        "~/.local/state/bbwf",
    ]

    # Google3 workspace extraction
    match = re.match(r"^(?P<workspace>/google/src/cloud/(?P<user>\w+)/[^/]+)", cwd)
    if match:
        paths.append(match.group("workspace"))
        paths.append(f"/usr/local/google/_blaze_{match.group('user')}")

    return paths


def _get_rw_paths(cwd: str) -> list[Path]:
    paths = _generate_rw_paths(cwd)
    paths_obj = [Path(p).expanduser() for p in paths]

    resolved = []
    for path_obj in paths_obj:
        path_obj = path_obj.resolve()
        assert path_obj.exists()
        assert path_obj.is_dir()
        resolved.append(path_obj)
    return resolved


def _build_docker_command(
    cwd: str,
    uid: int,
    gid: int,
    is_tty: bool,
    rw_paths: list[Path],
    tmpfs_paths: list[Path],
    env_vars: dict[str, str],
    cli_args: list[str],
) -> list[str]:
    docker_args = [
        "docker",
        "run",
        "-i",
        "--rm",
        "--net=host",
        "--ipc=host",
        "--pid=host",
        "--cap-add=SYS_ADMIN",
        "--security-opt",
        "apparmor=unconfined",
        "--security-opt",
        "seccomp=unconfined",
        "-v",
        "/:/real-root:ro",
        "-v",
        "/dev:/real-root/dev:ro",
        "-v",
        "/proc:/real-root/proc:ro",
        "--device",
        "/dev/kvm",
    ]

    if is_tty:
        docker_args.append("-t")

    for path in rw_paths:
        docker_args.extend(["-v", f"{path}:/real-root{path}"])

    for path in tmpfs_paths:
        docker_args.extend(["--tmpfs", f"/real-root{path}"])

    for key, value in env_vars.items():
        docker_args.extend(["-e", f"{key}={value}"])

    gemini_command = 'gemini --proxy=false "$@"'
    inner_script = f"""
mkdir -p /real-root/tmp/old_root
mount --rbind /real-root /real-root
cd /real-root
pivot_root . tmp/old_root
umount -l /tmp/old_root
mount -t proc proc /proc
exec env --chdir="{cwd}" setpriv --reuid "{uid}" --regid "{gid}" --init-groups \\
    {gemini_command}
"""

    docker_args.extend(
        [
            "busybox:latest",
            "sh",
            "-c",
            inner_script,
            "--",
        ]
    )
    docker_args.extend(cli_args)

    return docker_args


if "PYTEST_VERSION" in os.environ:
    import contextlib
    import tempfile
    import subprocess


    def test_get_allowlisted_env_vars():
        fake_env = {"PATH": "/bin", "USER": "ksp", "SECRET": "hidden"}
        result = _get_allowlisted_env_vars(fake_env)
        assert result == {"PATH": "/bin", "USER": "ksp"}
        assert "SECRET" not in result


    def test_generate_rw_paths():
        paths = _generate_rw_paths("/home/ksp/projects/foo")
        assert "/home/ksp/projects/foo" in paths
        assert "~/.gemini" in paths


    def test_generate_rw_paths_google3():
        paths = _generate_rw_paths("/google/src/cloud/ksp/my_workspace/google3/foo")
        assert "/google/src/cloud/ksp/my_workspace" in paths
        assert "/usr/local/google/_blaze_ksp" in paths


    def test_build_docker_command_tty():
        cmd_tty = _build_docker_command("/cwd", 1000, 1000, True, [], [], {}, ["--arg"])
        assert "-t" in cmd_tty

        cmd_notty = _build_docker_command("/cwd", 1000, 1000, False, [], [], {}, ["--arg"])
        assert "-t" not in cmd_notty

    def test_build_docker_command_formatting():
        cmd = _build_docker_command(
            cwd="/my/cwd",
            uid=1234,
            gid=5678,
            is_tty=False,
            rw_paths=[Path("/my/rw")],
            tmpfs_paths=[],
            env_vars={"MY_ENV": "value"},
            cli_args=["--foo", "bar"],
        )

        # Check mounts
        assert "-v" in cmd
        assert "/my/rw:/real-root/my/rw" in cmd

        # Check env vars
        assert "-e" in cmd
        assert "MY_ENV=value" in cmd

        # Check args appended at the end
        assert cmd[-2:] == ["--foo", "bar"]

        # Check inner script interpolation
        script_idx = cmd.index("-c") + 1
        inner_script = cmd[script_idx]
        assert '--chdir="/my/cwd"' in inner_script
        assert '--reuid "1234"' in inner_script
        assert '--regid "5678"' in inner_script

    def test_build_docker_command_tmpfs():
        cmd = _build_docker_command(
            cwd="/my/cwd",
            uid=1234,
            gid=5678,
            is_tty=False,
            rw_paths=[],
            tmpfs_paths=[Path("/my/tmpfs")],
            env_vars={},
            cli_args=[],
        )
        assert "--tmpfs" in cmd
        assert "/real-root/my/tmpfs" in cmd

    def test_valid_dir(tmp_path):
        import pytest
        
        # Test valid directory
        valid = valid_dir(str(tmp_path))
        assert isinstance(valid, Path)
        assert valid == tmp_path.resolve()

        # Test non-existent path
        with pytest.raises(argparse.ArgumentTypeError, match="does not exist"):
            valid_dir(str(tmp_path / "does_not_exist"))

        # Test file instead of directory
        test_file = tmp_path / "test_file.txt"
        test_file.touch()
        with pytest.raises(argparse.ArgumentTypeError, match="is not a valid directory"):
            valid_dir(str(test_file))


    def test_e2e():
        with tempfile.TemporaryDirectory() as d, chdir(d):
            bin_dir = Path(d) / "bin"
            bin_dir.mkdir()
            gemini_mock = bin_dir / "gemini"
            gemini_mock.write_text("#!/bin/sh\ntouch ./rw-test\ntouch ~/rw-test 2>/dev/null\nexit 0\n")
            gemini_mock.chmod(0o755)

            env = os.environ.copy()
            env["PATH"] = f"{bin_dir}:{env.get('PATH', '')}"

            subprocess.run(
                [
                    sys.executable,
                    __file__,
                    "-m",
                    "flash-lite",
                    "-y",
                    "-p",
                    """Call `run_shell_command("touch ./rw-test; touch ~/rw-test")`""",
                ],
                env=env,
                check=True,
            )
            assert Path("rw-test").exists()
            assert not Path("~/rw-test").expanduser().exists()


    @contextlib.contextmanager
    def chdir(new_cwd):
        old_cwd = os.getcwd()
        try:
            os.chdir(new_cwd)
            yield
        finally:
            os.chdir(old_cwd)


if __name__ == "__main__":
    main()
