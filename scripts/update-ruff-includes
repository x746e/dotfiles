#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = [
#     "GitPython",
#     "tomlkit",
# ]
# ///

"""Utility script to automatically update ruff.toml with extensionless Python scripts.

Ruff relies on file extensions to find Python files by default. This script scans
the repository for extensionless executable scripts and adds them to the
`extend-include` array in ruff.toml so that they are linted properly.
"""

import argparse
import sys
from pathlib import Path

import pytest
import tomlkit

import git


def is_extensionless_python_script(filepath: Path) -> bool:
    """Check if a file is an extensionless Python script based on its shebang."""
    if not filepath.is_file():
        return False

    if filepath.suffix:
        # Ruff automatically picks up .py files. We only care about extensionless files.
        return False

    with filepath.open("rb") as f:
        first_line = f.readline().decode("utf-8", errors="ignore").strip()

        # Check for typical Python shebangs
        if first_line.startswith("#!"):
            return "python" in first_line or "uv run" in first_line

    return False


def get_python_scripts_to_include(repo_root: Path) -> list[str]:
    """Find all extensionless Python scripts tracked by git."""
    python_scripts = []

    repo = git.Repo(repo_root)

    tracked_files = repo.git.ls_files().splitlines()
    for rel_path in tracked_files:
        filepath = repo_root / rel_path
        if not filepath.is_file():
            continue

        if is_extensionless_python_script(filepath):
            python_scripts.append(rel_path)

    return sorted(python_scripts)


def _read_ruff_toml(repo_root: Path) -> tuple[Path, tomlkit.TOMLDocument]:
    """Resolve the path and parse the ruff.toml configuration file."""
    ruff_toml_path = repo_root / "ruff" / "config" / "ruff.toml"

    if not ruff_toml_path.exists():
        raise FileNotFoundError(f"Could not find ruff.toml at {ruff_toml_path}")

    with ruff_toml_path.open("r", encoding="utf-8") as f:
        doc = tomlkit.parse(f.read())

    return ruff_toml_path, doc


def check_ruff_includes(repo_root: Path, scripts: list[str]) -> bool:
    """Check if the ruff.toml configuration file is up-to-date.

    Returns True if the file is up-to-date, False otherwise.
    """
    _, doc = _read_ruff_toml(repo_root)

    current_includes = list(doc.get("extend-include", []))
    if current_includes == scripts:
        return True

    added = set(scripts) - set(current_includes)
    removed = set(current_includes) - set(scripts)
    if added:
        print(f"Missing from ruff.toml: {', '.join(sorted(added))}")
    if removed:
        print(f"Extra in ruff.toml: {', '.join(sorted(removed))}")
    if not added and not removed:
        print("Order of scripts differs in ruff.toml")
    return False


def update_ruff_includes(repo_root: Path, scripts: list[str]) -> bool:
    """Update the ruff.toml configuration file with the provided scripts.

    Returns True if the file was modified, False if it was already up-to-date.
    """
    ruff_toml_path, doc = _read_ruff_toml(repo_root)

    current_includes = list(doc.get("extend-include", []))
    if current_includes == scripts:
        return False

    # Create a multiline array for clean formatting
    arr = tomlkit.array()
    for script in scripts:
        arr.append(script)
    arr.multiline(True)

    doc["extend-include"] = arr

    with ruff_toml_path.open("w", encoding="utf-8") as f:
        f.write(tomlkit.dumps(doc))
    return True


def main() -> None:
    """Discover extensionless Python scripts and update ruff.toml."""
    parser = argparse.ArgumentParser(
        description="Update ruff.toml with extensionless Python scripts."
    )
    parser.add_argument(
        "--check",
        action="store_true",
        help="Check if ruff.toml is up-to-date without modifying it.",
    )
    args = parser.parse_args()

    # Determine repo root relative to this script
    script_path = Path(__file__).resolve()
    repo_root = script_path.parent.parent

    python_scripts = get_python_scripts_to_include(repo_root)

    if args.check:
        is_up_to_date = check_ruff_includes(repo_root, python_scripts)
        if is_up_to_date:
            print("ruff.toml is up-to-date.")
            sys.exit(0)
        else:
            print(
                "Error: ruff.toml 'extend-include' is out of date. "
                "Run without --check to update.",
                file=sys.stderr,
            )
            sys.exit(1)

    updated = update_ruff_includes(repo_root, python_scripts)

    if updated:
        print(
            f"Successfully updated 'extend-include' in ruff.toml "
            f"with {len(python_scripts)} scripts."
        )
        for script in python_scripts:
            print(f"  - {script}")


# --- Tests ---


# ruff: disable[D103]
def test_read_ruff_toml_missing_file(tmp_path: Path):
    with pytest.raises(FileNotFoundError):
        _read_ruff_toml(tmp_path)


def test_check_ruff_includes_deterministic_output(tmp_path: Path, capsys):
    # Setup mock repo structure
    ruff_dir = tmp_path / "ruff" / "config"
    ruff_dir.mkdir(parents=True)
    ruff_toml = ruff_dir / "ruff.toml"
    ruff_toml.write_text("extend-include = ['b_script', 'd_script']\n")

    # We add a_script and c_script, we remove b_script and d_script
    # If not sorted, the output order is random due to hash randomization
    scripts = ["a_script", "c_script"]

    result = check_ruff_includes(tmp_path, scripts)
    assert result is False

    captured = capsys.readouterr()
    assert "Missing from ruff.toml: a_script, c_script" in captured.out
    assert "Extra in ruff.toml: b_script, d_script" in captured.out


def test_is_extensionless_python_script(tmp_path: Path):
    # Valid Python script with shebang
    py_script = tmp_path / "my_script"
    py_script.write_text("#!/usr/bin/env python\nprint('hello')\n")
    assert is_extensionless_python_script(py_script) is True

    # Valid uv run script
    uv_script = tmp_path / "uv_script"
    uv_script.write_text("#!/usr/bin/env -S uv run\nprint('hello')\n")
    assert is_extensionless_python_script(uv_script) is True

    # File with extension
    ext_script = tmp_path / "script.py"
    ext_script.write_text("#!/usr/bin/env python\nprint('hello')\n")
    assert is_extensionless_python_script(ext_script) is False

    # Bash script
    bash_script = tmp_path / "bash_script"
    bash_script.write_text("#!/bin/bash\necho 'hello'\n")
    assert is_extensionless_python_script(bash_script) is False

    # Empty file
    empty_file = tmp_path / "empty"
    empty_file.write_text("")
    assert is_extensionless_python_script(empty_file) is False


def test_get_python_scripts_to_include(tmp_path: Path):
    # Setup mock repo structure
    repo = git.Repo.init(tmp_path)

    # Configure git author so commits don't fail in restricted environments
    with repo.config_writer() as cw:
        cw.set_value("user", "name", "Test User")
        cw.set_value("user", "email", "test@example.com")

    # Setup mock .gitignore
    ignored_dir = tmp_path / "ignored_dir"
    ignored_dir.mkdir()
    (tmp_path / ".gitignore").write_text("ignored_dir/\n")

    # Create files

    # 1. Committed
    committed_script = tmp_path / "committed_script"
    committed_script.write_text("#!/usr/bin/env python\n")
    repo.index.add(["committed_script"])
    repo.index.commit("Initial commit")

    # 2. Staged
    staged_script = tmp_path / "staged_script"
    staged_script.write_text("#!/usr/bin/env python\n")
    repo.index.add(["staged_script"])

    # 3. Modified (Unstaged)
    modified_script = tmp_path / "modified_script"
    modified_script.write_text("#!/usr/bin/env python\n")
    repo.index.add(["modified_script"])
    repo.index.commit("Second commit")
    modified_script.write_text("#!/usr/bin/env python\n# Modified\n")

    # 4. Deleted (Unstaged)
    deleted_script = tmp_path / "deleted_script"
    deleted_script.write_text("#!/usr/bin/env python\n")
    repo.index.add(["deleted_script"])
    repo.index.commit("Third commit")
    deleted_script.unlink()

    # 5. Untracked
    untracked_script = tmp_path / "untracked_script"
    untracked_script.write_text("#!/usr/bin/env python\n")

    # 6. Gitignored
    gitignored_script = ignored_dir / "gitignored_script"
    gitignored_script.write_text("#!/usr/bin/env python\n")

    found_scripts = get_python_scripts_to_include(tmp_path)

    assert "committed_script" in found_scripts
    assert "staged_script" in found_scripts
    assert "modified_script" in found_scripts
    assert "deleted_script" not in found_scripts
    assert "untracked_script" not in found_scripts
    assert "ignored_dir/gitignored_script" not in found_scripts
    assert len(found_scripts) == 3


def test_update_ruff_includes(tmp_path: Path):
    # Setup mock repo structure
    ruff_dir = tmp_path / "ruff" / "config"
    ruff_dir.mkdir(parents=True)
    ruff_toml = ruff_dir / "ruff.toml"
    ruff_toml.write_text("extend-include = ['old_script']\n")

    # Test update when changes are needed
    scripts = ["new_script", "another_script"]
    result = update_ruff_includes(tmp_path, scripts)
    assert result is True
    assert "new_script" in ruff_toml.read_text()
    assert "old_script" not in ruff_toml.read_text()

    # Test update when already up-to-date
    result2 = update_ruff_includes(tmp_path, scripts)
    assert result2 is False


def test_check_ruff_includes(tmp_path: Path):
    # Setup mock repo structure
    ruff_dir = tmp_path / "ruff" / "config"
    ruff_dir.mkdir(parents=True)
    ruff_toml = ruff_dir / "ruff.toml"
    ruff_toml.write_text("extend-include = ['new_script', 'another_script']\n")

    scripts = ["new_script", "another_script"]

    # Test check when up-to-date
    result = check_ruff_includes(tmp_path, scripts)
    assert result is True

    # Test check when order differs
    scripts_reversed = ["another_script", "new_script"]
    result = check_ruff_includes(tmp_path, scripts_reversed)
    assert result is False

    # Test check when out-of-date
    scripts.append("yet_another_script")
    old_content = ruff_toml.read_text()
    result = check_ruff_includes(tmp_path, scripts)
    assert result is False
    assert ruff_toml.read_text() == old_content


# ruff: enable[D103]


if __name__ == "__main__":
    main()
